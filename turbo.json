{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "//#lint": {
      "cache": false
    },
    "//#docker-build": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "//#tunnel": {
      "cache": false,
      "persistent": true
    }
  }
}
