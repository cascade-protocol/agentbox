{
  "name": "openclaw-agentbox",
  "version": "1.0.5",
  "description": "OpenClaw plugin for AgentBox - x402 USDC payments, Solana wallet, token trading",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "bin": {
    "openclaw-agentbox": "dist/bin/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsdown --publint && cp openclaw.plugin.json dist/",
    "dev": "tsdown --watch",
    "type-check": "tsc --noEmit",
    "check": "pnpm type-check && biome check --write",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "x402-proxy": "workspace:*",
    "@noble/curves": "^1.9.0",
    "@noble/hashes": "^1.8.0",
    "@scure/base": "^1.2.0",
    "@scure/bip32": "^1.7.0",
    "@scure/bip39": "^1.6.0",
    "@sinclair/typebox": "^0.34.48",
    "@solana/kit": "^6.0.0",
    "ethers": "^6.0.0",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": ">=2026.3.8",
    "publint": "^0.3.17",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.0"
  },
  "files": [
    "dist/**",
    "openclaw.plugin.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "keywords": [
    "openclaw",
    "agentbox",
    "x402",
    "solana",
    "usdc",
    "payment",
    "trading"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cascade-protocol/agentbox.git",
    "directory": "packages/openclaw-agentbox"
  },
  "homepage": "https://github.com/cascade-protocol/agentbox/tree/main/packages/openclaw-agentbox#readme",
  "bugs": {
    "url": "https://github.com/cascade-protocol/agentbox/issues"
  }
}
